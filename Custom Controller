void KEYPAD_INIT () {
	DDRB = 0b00000000;
	DDRC = 0b00000000;
	DDRD = 0b00000000;
	PORTB = 0b11111111;
	PORTC = 0b11111111;
	PORTD = 0b11111111;
}

void FACE_BUTTONS () {
	if ((PINC & 0b10000000) == 0) {
		Y = 1;
	} else Y = 0;
	
	if ((PINC & 0b01000000) == 0) {
		X = 1;
	} else X = 0;
	
	if ((PINC & 0b00100000) == 0) {
		B = 1;
	} else B = 0;
	
	if ((PINC & 0b00010000) == 0) {
		A = 1;
	} else A = 0;
}

void DPAD_BUTTONS () {
	if ((PINC & 0b00001000) == 0) {
		UP = 1;
	} else UP = 0;
	
	if ((PINC & 0b00000100) == 0) {
		LEFT = 1;
	} else LEFT = 0;
	
	if ((PINC & 0b00000010) == 0) {
		RIGHT = 1;
	} else RIGHT = 0;
	
	if ((PINC & 0b00000001) == 0) {
		DOWN = 1;
	} else DOWN = 0;
}

void TRIG_BUMP_BUTTONS () {
	if ((PIND & 0b10000000) == 0) {
		RT = 1;
	} else RT = 0;
	
	if ((PIND & 0b01000000) == 0) {
		LT = 1;
	} else LT = 0;
	
	if ((PIND & 0b00100000) == 0) {
		RB = 1;
	} else RB = 0;
	
	if ((PIND & 0b00010000) == 0) {
		LB = 1;
	} else LB = 0;
}

void PROGRAMMABLE_BUTTONS () {
	if ((PINB & 0b00001000) == 0) {
		PS1 = 1;
	} else PS1 = 0;
	
	if ((PINB & 0b00000100) == 0) {
		PS2 = 1;
	} else PS2 = 0;
	
	if ((PINB & 0b00000010) == 0) {
		PS3 = 1;
	} else PS3 = 0;
	
	if ((PINB & 0b00000001) == 0) {
		PS4 = 1;
	} else PS4 = 0;
}

//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

int main (void) {
	ADC_INIT ();
	KEYPAD_INIT ();
	UART_INIT (250000);

	while (1) {
		X1 = ADC_READ (0);
		Y1 = ADC_READ (1);
		X2 = ADC_READ (3);
		Y2 = ADC_READ (4);
		
		if ((PINA & 0b00000100) == 0) {
			B1 = 1;
		} else B1 = 0;
		
		if ((PINA & 0b00100000) == 0) {
			B2 = 1;
		} else B2 = 0;
		
		FACE_BUTTONS ();
		DPAD_BUTTONS ();
		TRIG_BUMP_BUTTONS ();
		PROGRAMMABLE_BUTTONS ();
		
		SEND_IBUS ();
		 
		_delay_ms (4);
	}
}

